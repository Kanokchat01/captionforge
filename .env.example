# Track 2 injects NO api key/model restriction — use your own credentials.
# For local dev, copy this to .env. Do NOT bundle a real .env into the
# submitted Docker image (per Participant Guide instructions).

# Required: primary captioner (native video+audio multimodal)
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: Gemma polish + self-critique via Fireworks, for the Best Use of
# Gemma bonus prize. Pipeline still works (Gemini-only) if left blank.
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_GEMMA_MODEL=accounts/fireworks/models/gemma3-27b-it

ENABLE_GEMMA_POLISH=true
ENABLE_SELF_CRITIQUE=true
MAX_CRITIQUE_RETRIES=2
CRITIQUE_PASS_THRESHOLD=8

# Orchestration — tune these AFTER timing a real run against the 3 sample
# clips; hard ceiling is 10 minutes total for ~12 hidden clips.
CONCURRENCY=4
TOTAL_BUDGET_SECONDS=540
PER_REQUEST_TIMEOUT_SECONDS=28
